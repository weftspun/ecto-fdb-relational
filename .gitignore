# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
ecto_fdb_relational-*.tar

# Rust NIF build artifacts (native/ecto_fdb_relational_nif, built via "mix compile" -- see
# mix.exs and ADR 0003). Cargo.lock *is* tracked (see native/ecto_fdb_relational_nif/Cargo.lock).
/native/ecto_fdb_relational_nif/target/
/priv/native/

# Compiled Java bridge classes (native/frl_bridge/src, compiled by mix.exs's :frl_bridge
# compiler into priv/java/ -- see ADR 0003). Requires the FRL jars + a JDK to rebuild.
/priv/java/

